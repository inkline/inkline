{
  "name": "@inkline/plugin",
  "version": "0.0.0",
  "description": "Build plugin for @inkline/compiler — compile .ink.tsx files to framework components (Vite, webpack, Rollup, esbuild, Rspack, Farm)",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.cjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.mts",
      "import": "./dist/webpack.mjs",
      "require": "./dist/webpack.cjs"
    },
    "./rollup": {
      "types": "./dist/rollup.d.mts",
      "import": "./dist/rollup.mjs",
      "require": "./dist/rollup.cjs"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.mts",
      "import": "./dist/esbuild.mjs",
      "require": "./dist/esbuild.cjs"
    },
    "./rspack": {
      "types": "./dist/rspack.d.mts",
      "import": "./dist/rspack.mjs",
      "require": "./dist/rspack.cjs"
    },
    "./farm": {
      "types": "./dist/farm.d.mts",
      "import": "./dist/farm.mjs",
      "require": "./dist/farm.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "unbuild --watch"
  },
  "dependencies": {
    "@inkline/compiler": "workspace:*",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "catalog:ts6",
    "unbuild": "^3.6.1",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@farmfe/core": ">=1",
    "@rspack/core": ">=1",
    "esbuild": "*",
    "rollup": "^3 || ^4",
    "vite": ">=5",
    "webpack": "^4 || ^5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "@rspack/core": {
      "optional": true
    },
    "@farmfe/core": {
      "optional": true
    }
  }
}
