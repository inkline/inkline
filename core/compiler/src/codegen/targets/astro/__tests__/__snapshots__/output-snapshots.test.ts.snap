exports[`astro full output snapshots > DynamicList 1`] = `
"---
type Props = Record<string, any>
const props = Astro.props as Props;
const { ...__attrs } = props;
let items = []
let input = ""
---
<div {...__attrs} class={__attrs.class}>
<input value={input} onInput={e => input = e.target.value} />
<button onClick={() => { items = [...items, input]; input = ""; }}>
Add
</button>
<ul>
{items.map((item, i) => (<li>
{item}
</li>))}
</ul>
</div>
"
`;

