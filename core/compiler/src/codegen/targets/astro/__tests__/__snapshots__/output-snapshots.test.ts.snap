// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`astro full output snapshots > BatchUpdates 1`] = `
"---
type Props = Record<string, any>
const props = Astro.props as Props;
const { ...__attrs } = props;
let x = 0
let y = 0
const sum = x + y
---
<div {...__attrs} class={__attrs.class}>
<span>
{sum}
</span>
<button onClick={() => { x = x + 1; y = y + 1; }}>
Both
</button>
</div>
"
`;

