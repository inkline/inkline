exports[`astro full output snapshots > Composite 1`] = `
"---
type Props = Record<string, any>
const props = Astro.props as Props;
const { ...__attrs } = props;
let x = 1
let y = 2
const sum = x + y
---
<div {...__attrs} class={__attrs.class}>
<span id="sum">
{sum}
</span>
<button id="incX" onClick={() => x = x + 1}>
+X
</button>
<button id="incY" onClick={() => y = y + 1}>
+Y
</button>
</div>
"
`;

exports[`astro full output snapshots > Conditional 1`] = `
"---
type Props = Record<string, any>
const props = Astro.props as Props;
const { ...__attrs } = props;
let visible = true
---
<div {...__attrs} class={__attrs.class}>
{visible ? (<span>
Visible
</span>) : (<span>
Hidden
</span>)}
<button onClick={() => visible = !visible}>
Toggle
</button>
</div>
"
`;

