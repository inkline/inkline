exports[`react full output snapshots > SwitchTabs 1`] = `
"import { useState } from "react";
export function SwitchTabs(props: React.HTMLAttributes<HTMLElement>)
{
const [tab, setTab] = useState("a")
const { ...__attrs } = props
return (
<div {...__attrs} className={props.className}>
  {tab === "a" ? <p>Tab A</p> : tab === "b" ? <p>Tab B</p> : null}
  <button onClick={() => setTab(tab === "a" ? "b" : "a")}>Switch</button>
</div>
)
}
"
`;

exports[`react multi-component files > ComponentRef (all files) 1`] = `
"export function Child(props: React.HTMLAttributes<HTMLElement>)
{
const { ...__attrs } = props
return (
<div {...__attrs} className={props.className}>Child</div>
)
}

import { useRef, useEffect, forwardRef } from "react";
export const ComponentRef = forwardRef(function ComponentRef(props: React.HTMLAttributes<HTMLElement>, ref)
{
const childRef = useRef(null)
useEffect(() => { console.log(childRef.current); }, [])
const { ...__attrs } = props
return (
<Child {...__attrs} className={props.className} ref={childRef} />
)
});
"
`;
