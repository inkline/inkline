exports[`react full output snapshots > Lifecycle 1`] = `
"import { useState, useEffect } from "react";
export function Lifecycle(props: React.HTMLAttributes<HTMLElement>)
{
const [mounted, setMounted] = useState(false)
useEffect(() => { setMounted(true); }, [])
useEffect(() => () => { console.log("cleanup"); }, [])
const { ...__attrs } = props
return (
<span {...__attrs} className={props.className}>{mounted ? "mounted" : "pending"}</span>
)
}
"
`;

exports[`react full output snapshots > MemoChain 1`] = `
"import { useState, useMemo } from "react";
export function MemoChain(props: React.HTMLAttributes<HTMLElement>)
{
const [base, setBase] = useState(1)
const doubled = useMemo(() => base * 2, [base])
const quadrupled = useMemo(() => doubled * 2, [doubled])
const label = useMemo(() => \`Value: \${quadrupled}\`, [quadrupled])
const { ...__attrs } = props
return (
<div {...__attrs} className={props.className}>
  <span>{label}</span>
  <button onClick={() => setBase(base + 1)}>+1</button>
</div>
)
}
"
`;

