// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`react full output snapshots > BatchUpdates 1`] = `
"import { useState, useMemo } from "react";
export function BatchUpdates(props: React.HTMLAttributes<HTMLElement>)
{
const [x, setX] = useState(0)
const [y, setY] = useState(0)
const sum = useMemo(() => x + y, [x, y])
const { ...__attrs } = props
return (
<div {...__attrs} className={props.className}>
  <span>{sum}</span>
  <button onClick={() => { setX(x + 1); setY(y + 1); }}>Both</button>
</div>
)
}
"
`;

exports[`react full output snapshots > BoundField 1`] = `
"export function Field(props: { value?: string; onUpdateValue?: (value: string) => void } & React.HTMLAttributes<HTMLElement>)
{
const { value, onUpdateValue, ...__attrs } = props
return (
<input {...__attrs} value={props.value} className={props.className} onInput={e => props.onUpdateValue?.(e.target.value)} />
)
}
"
`;

exports[`react full output snapshots > Composite 1`] = `
"import { useState, useMemo, useEffect } from "react";
export function Composite(props: React.HTMLAttributes<HTMLElement>)
{
const [x, setX] = useState(1)
const [y, setY] = useState(2)
const sum = useMemo(() => x + y, [x, y])
useEffect(() => { console.log("sum:", sum); }, [sum])
const { ...__attrs } = props
return (
<div {...__attrs} className={props.className}>
  <span id="sum">{sum}</span>
  <button id="incX" onClick={() => setX(x + 1)}>+X</button>
  <button id="incY" onClick={() => setY(y + 1)}>+Y</button>
</div>
)
}
"
`;

exports[`react full output snapshots > Conditional 1`] = `
"import { useState } from "react";
export function Conditional(props: React.HTMLAttributes<HTMLElement>)
{
const [visible, setVisible] = useState(true)
const { ...__attrs } = props
return (
<div {...__attrs} className={props.className}>
  {visible ? <span>Visible</span> : <span>Hidden</span>}
  <button onClick={() => setVisible(!visible)}>Toggle</button>
</div>
)
}
"
`;

