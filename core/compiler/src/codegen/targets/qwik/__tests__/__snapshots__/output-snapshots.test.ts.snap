exports[`qwik full output snapshots > Composite 1`] = `
"import { component$, useSignal, useComputed$, useVisibleTask$, $ } from "@qwik.dev/core";
export const Composite = component$((props) =>
{
const x = useSignal(1)
const y = useSignal(2)
const sum = useComputed$(() => x.value + y.value)
useVisibleTask$(() => { console.log("sum:", sum.value); })
const { ...__attrs } = props
return (
<div {...__attrs} class={props.class}>
  <span id="sum">{sum.value}</span>
  <button id="incX" onClick={$(() => x.value = x.value + 1)}>+X</button>
  <button id="incY" onClick={$(() => y.value = y.value + 1)}>+Y</button>
</div>
)
});
"
`;

