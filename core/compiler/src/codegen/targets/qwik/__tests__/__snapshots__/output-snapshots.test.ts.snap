exports[`qwik full output snapshots > BatchUpdates 1`] = `
"import { component$, useSignal, useComputed$, useVisibleTask$, $ } from "@qwik.dev/core";
export const BatchUpdates = component$((props) =>
{
const x = useSignal(0)
const y = useSignal(0)
const sum = useComputed$(() => x.value + y.value)
const { ...__attrs } = props
return (
<div {...__attrs} class={props.class}>
  <span>{sum.value}</span>
  <button onClick={$(() => { x.value = x.value + 1; y.value = y.value + 1; })}>Both</button>
</div>
)
});
"
`;

