"import { component$, useSignal, useComputed$, useVisibleTask$, $ } from "@qwik.dev/core";
export const MemoChain = component$((props) =>
{
const base = useSignal(1)
const doubled = useComputed$(() => base.value * 2)
const quadrupled = useComputed$(() => doubled.value * 2)
const label = useComputed$(() => \`Value: \${quadrupled.value}\`)
const { ...__attrs } = props
return (
<div {...__attrs} class={props.class}>
  <span>{label.value}</span>
  <button onClick={$(() => base.value = base.value + 1)}>+1</button>
</div>
)
});
"
`;

