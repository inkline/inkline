exports[`qwik full output snapshots > DynamicList 1`] = `
"import { component$, useSignal, useComputed$, useVisibleTask$, $ } from "@qwik.dev/core";
export const DynamicList = component$((props) =>
{
const items = useSignal([])
const input = useSignal("")
const { ...__attrs } = props
return (
<div {...__attrs} class={props.class}>
  <input value={input.value} onInput={$(e => input.value = e.target.value)} />
  <button onClick={$(() => { items.value = [...items.value, input.value]; input.value = ""; })}>Add</button>
  <ul>
    {items.value.map((item, i) => (<><li>{item}</li></>))}
  </ul>
</div>
)
});
"
`;

