return (
<span {...__attrs} class={props.class}>
  {mounted() ? "mounted" : "pending"}
</span>
)
}
"
`;

exports[`solid full output snapshots > MemoChain 1`] = `
"import { createSignal, createMemo, splitProps } from "solid-js";
import type { JSX } from "solid-js";
export default function MemoChain(props: JSX.HTMLAttributes<HTMLElement>)
{
const [base, setBase] = createSignal(1)
const doubled = createMemo(() => base() * 2)
const quadrupled = createMemo(() => doubled() * 2)
const label = createMemo(() => \`Value: \${quadrupled()}\`)
const [, __attrs] = splitProps(props, [])
return (
<div {...__attrs} class={props.class}>
  <span>
    {label()}
  </span>
  <button onclick={() => setBase(base() + 1)}>
    +1
  </button>
</div>
)
}
"
`;

