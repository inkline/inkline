exports[`solid full output snapshots > SwitchTabs 1`] = `
"import { createSignal, splitProps, Switch, Match } from "solid-js";
import type { JSX } from "solid-js";
export default function SwitchTabs(props: JSX.HTMLAttributes<HTMLElement>)
{
const [tab, setTab] = createSignal("a")
const [, __attrs] = splitProps(props, [])
return (
<div {...__attrs} class={props.class}>
  <Switch>
    <Match when={tab() === "a"}>
      <p>
        Tab A
      </p>
    </Match>
    <Match when={tab() === "b"}>
      <p>
        Tab B
      </p>
    </Match>
  </Switch>
  <button onclick={() => setTab(tab() === "a" ? "b" : "a")}>
    Switch
  </button>
</div>
)
}
"
`;

