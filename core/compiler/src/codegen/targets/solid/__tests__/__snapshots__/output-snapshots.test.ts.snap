exports[`solid full output snapshots > Composite 1`] = `
"import { createSignal, createMemo, createEffect, splitProps } from "solid-js";
import type { JSX } from "solid-js";
export default function Composite(props: JSX.HTMLAttributes<HTMLElement>)
{
const [x, setX] = createSignal(1)
const [y, setY] = createSignal(2)
const sum = createMemo(() => x() + y())
createEffect(() => { console.log("sum:", sum()); })
const [, __attrs] = splitProps(props, [])
return (
<div {...__attrs} class={props.class}>
  <span id="sum">
    {sum()}
  </span>
  <button id="incX" onclick={() => setX(x() + 1)}>
    +X
  </button>
  <button id="incY" onclick={() => setY(y() + 1)}>
    +Y
  </button>
</div>
)
}
"
`;

exports[`solid full output snapshots > Conditional 1`] = `
"import { createSignal, splitProps, Show } from "solid-js";
import type { JSX } from "solid-js";
export default function Conditional(props: JSX.HTMLAttributes<HTMLElement>)
{
const [visible, setVisible] = createSignal(true)
const [, __attrs] = splitProps(props, [])
return (
<div {...__attrs} class={props.class}>
  <Show when={visible()} fallback={<><span>Hidden</span></>}>
    <span>
      Visible
    </span>
  </Show>
  <button onclick={() => setVisible(!visible())}>
    Toggle
  </button>
</div>
)
}
"
`;

exports[`solid full output snapshots > ConditionalClass 1`] = `
"import { createSignal, splitProps } from "solid-js";
import type { JSX } from "solid-js";
export default function ConditionalClass(props: JSX.HTMLAttributes<HTMLElement>)
{
const [active, setActive] = createSignal(false)
const [, __attrs] = splitProps(props, [])
return (
<div {...__attrs} class={[active() ? "active" : "inactive", props.class].filter(Boolean).join(" ")}>
  <button onclick={() => setActive(!active())}>
    Toggle
  </button>
</div>
)
}
"
`;

