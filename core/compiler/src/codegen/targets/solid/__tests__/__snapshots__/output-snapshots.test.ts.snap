exports[`solid full output snapshots > BatchUpdates 1`] = `
"import { createSignal, createMemo, splitProps } from "solid-js";
import type { JSX } from "solid-js";
export default function BatchUpdates(props: JSX.HTMLAttributes<HTMLElement>)
{
const [x, setX] = createSignal(0)
const [y, setY] = createSignal(0)
const sum = createMemo(() => x() + y())
const [, __attrs] = splitProps(props, [])
return (
<div {...__attrs} class={props.class}>
  <span>
    {sum()}
  </span>
  <button onclick={() => { setX(x() + 1); setY(y() + 1); }}>
    Both
  </button>
</div>
)
}
"
`;

exports[`solid full output snapshots > BoundField 1`] = `
"import { splitProps } from "solid-js";
import type { JSX } from "solid-js";
export default function Field(props: { value?: string; onUpdateValue?: (value: string) => void } & JSX.HTMLAttributes<HTMLElement>)
{
const [, __attrs] = splitProps(props, ["value", "onUpdateValue"])
return (
<input {...__attrs} value={props.value} class={props.class} oninput={e => props.onUpdateValue?.(e.target.value)} />
)
}
"
