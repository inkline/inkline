exports[`solid full output snapshots > Counter 1`] = `
"import { createSignal, createMemo, createEffect, splitProps } from "solid-js";
import type { JSX } from "solid-js";
export default function Counter(props: JSX.HTMLAttributes<HTMLElement>)
{
const [count, setCount] = createSignal(0)
const doubled = createMemo(() => count() * 2)
createEffect(() => { console.log("count:", count()); })
const [, __attrs] = splitProps(props, [])
return (
<div {...__attrs} class={props.class}>
  <p>
    {count()}
  </p>
  <p>
    {doubled()}
  </p>
  <button onclick={() => setCount(count() + 1)}>
    +1
  </button>
</div>
)
}
"
`;

