exports[`control flow emission > Solid: Switch with fallback 1`] = `
"import { createSignal, createMemo, createEffect, Switch, Match } from "solid-js";
export default function Sw(props: Record<string, never>)
{
const [count, setCount] = createSignal(0)
const doubled = createMemo(() => count() * 2)
createEffect(() => { console.log("effect"); })
return (
<div>
  <Switch fallback={<>default</>}>
    <Match when={x()}>
      X
    </Match>
    <Match when={y()}>
      Y
    </Match>
  </Switch>
</div>
)
}
"
`;

