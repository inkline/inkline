exports[`Angular target > Counter component 1`] = `
"import { Component, signal, computed, effect } from "@angular/core";
@Component({ standalone: true, template: \`<div>
<p>
{{ count() }}
</p>
<button (click)="() => setCount(count() + 1)">
+1
</button>
</div>\` })
export class CounterComponent
{
count = signal(0)
doubled = computed(() => count() * 2)
constructor() { effect(() => { console.log("effect"); }) }
}
"
`;

