// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`vue full output snapshots > BatchUpdates 1`] = `
"<script setup lang="ts">
  import { ref, computed } from "vue";
  const x = ref(0)
  const y = ref(0)
  const sum = computed(() => x.value + y.value)
</script>
<template>
<div>
  <span>{{ sum }}</span>
  <button @click="() => { x = x + 1; y = y + 1; }">Both</button>
</div>
</template>
"
`;

