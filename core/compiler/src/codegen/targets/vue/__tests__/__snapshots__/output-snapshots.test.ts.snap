exports[`vue full output snapshots > DynamicList 1`] = `
"<script setup lang="ts">
  import { ref } from "vue";
  const items = ref([])
  const input = ref("")
</script>
<template>
<div>
  <input :value="input" @input="e => input = e.target.value" />
  <button @click='() => { items = [...items, input]; input = ""; }'>Add</button>
  <ul>
    <li v-for="(item, i) in items" :key="i">
      {{ item }}
    </li>
  </ul>
</div>
</template>
"
`;

exports[`vue full output snapshots > EffectCleanup 1`] = `
"<script setup lang="ts">
  import { ref, watchEffect } from "vue";
  const active = ref(true)
  watchEffect(() => { if (active.value) { const id = setInterval(() => console.log("tick"), 1000); return () => clearInterval(id); } })
</script>
<template>
<button @click="() => active = !active">Toggle</button>
</template>
"
`;

