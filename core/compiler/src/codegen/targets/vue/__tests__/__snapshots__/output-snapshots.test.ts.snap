</script>
<template>
<span>{{ mounted ? "mounted" : "pending" }}</span>
</template>
"
`;

exports[`vue full output snapshots > MemoChain 1`] = `
"<script setup lang="ts">
  import { ref, computed } from "vue";
  const base = ref(1)
  const doubled = computed(() => base.value * 2)
  const quadrupled = computed(() => doubled.value * 2)
  const label = computed(() => \`Value: \${quadrupled.value}\`)
</script>
<template>
<div>
  <span>{{ label }}</span>
  <button @click="() => base = base + 1">+1</button>
</div>
</template>
"
`;

exports[`vue full output snapshots > MixedControlFlow 1`] = `
