exports[`vue full output snapshots > SwitchTabs 1`] = `
"<script setup lang="ts">
  import { ref } from "vue";
  const tab = ref("a")
</script>
<template>
<div>
  <p v-if='tab === "a"'>
    Tab A
  </p>
  <p v-else-if='tab === "b"'>
    Tab B
  </p>
  <button @click='() => tab = tab === "a" ? "b" : "a"'>Switch</button>
</div>
</template>
"
`;

