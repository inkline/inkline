exports[`vue full output snapshots > Composite 1`] = `
"<script setup lang="ts">
  import { ref, computed, watchEffect } from "vue";
  const x = ref(1)
  const y = ref(2)
  const sum = computed(() => x.value + y.value)
  watchEffect(() => { console.log("sum:", sum.value); })
</script>
<template>
<div>
  <span id="sum">{{ sum }}</span>
  <button id="incX" @click="() => x = x + 1">+X</button>
  <button id="incY" @click="() => y = y + 1">+Y</button>
</div>
</template>
"
`;

