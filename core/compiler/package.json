{
  "name": "@inkline/compiler",
  "version": "0.1.0",
  "description": "Inkline compiler: TSX with signal primitives to per-target component output via a typed IR.",
  "homepage": "https://github.com/inkline/inkline#readme",
  "bugs": {
    "url": "https://github.com/inkline/inkline/issues"
  },
  "license": "MIT",
  "author": "Inkline contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inkline/inkline.git",
    "directory": "core/compiler"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "bench": "node --experimental-strip-types --experimental-transform-types scripts/bench.ts",
    "docs:diagnostics": "node --experimental-strip-types --experimental-transform-types scripts/gen-diagnostics.ts",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "catalog:",
    "@angular-eslint/template-parser": "catalog:",
    "@inkline/core": "workspace:*",
    "@jridgewell/trace-mapping": "^0.3.31",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vue/server-renderer": "catalog:",
    "bumpp": "^11.1.0",
    "eslint": "catalog:",
    "eslint-plugin-astro": "catalog:",
    "eslint-plugin-qwik": "catalog:",
    "eslint-plugin-solid": "catalog:",
    "eslint-plugin-svelte": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "happy-dom": "^20.10.3",
    "oxlint": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "solid-js": "catalog:",
    "svelte": "catalog:",
    "tinybench": "^6.0.2",
    "tsx": "catalog:",
    "typescript": "catalog:ts6",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-eslint-parser": "catalog:"
  },
  "peerDependencies": {
    "typescript": ">=5.4 <8"
  }
}
