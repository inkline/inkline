return (
<ICheckboxBase {...__attrs} class={[wrapperClassName(), props.class].filter(Boolean).join(" ")}>
  <>
    <ICheckboxControlBase class={fieldClassName()} id={props.id} name={props.name} disabled={props.disabled} required={props.required} readonly={props.readonly} indeterminate={props.indeterminate} checked={props.checked} onUpdateChecked={v => props.onUpdateChecked?.(v)} />
    {props.children ?? props.label}
