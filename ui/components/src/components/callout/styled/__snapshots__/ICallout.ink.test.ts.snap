    </ICalloutContentBase>
    {!!props.dismissible ? <ICalloutDismissBase ariaLabel={props.dismissAriaLabel} onClick={() => { setDismissed(true); props.onUpdateVisible?.(false); }}>{props.dismiss ?? "×"}</ICalloutDismissBase> : null}
