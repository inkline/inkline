  switchRecipe,
  switchFieldRecipe,
  type SwitchFieldRecipeProps as SwitchFieldStylingProps,
} from "virtual:styleframe";
export interface SwitchProps extends SwitchControlBaseProps {
  /** Off-state track colour. */
  color?: SwitchFieldStylingProps["color"];
