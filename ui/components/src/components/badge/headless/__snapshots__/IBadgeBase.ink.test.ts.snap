// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Badge > output matches snapshots 1`] = `
{
  "angular/IBadgeBase.component.ts": "import { Component, signal, computed, effect, input } from "@angular/core";
export interface BadgeBaseProps {
  label?: string;
}
@Component({ standalone: true, selector: 'ink-badge-base', host: { style: 'display: contents' }, template: \`<div [class]="'badge' + (klass() ? ' ' + klass() : '')">
<ng-content>{{ label() }}</ng-content>
</div>\` })
export class IBadgeBaseComponent
{
klass = input<string>()
label = input<string>()
}
@Component({ standalone: true, selector: 'div[ink-badge-base]', host: { '[class]': "'badge' + (klass() ? ' ' + klass() : '')" }, template: \`<ng-content>{{ label() }}</ng-content>\` })
export class IBadgeBaseHostComponent
{
klass = input<string>()
label = input<string>()
}
",
  "astro/IBadgeBase.astro": "---
export interface BadgeBaseProps {
  label?: string;
}
type Props = BadgeBaseProps & Record<string, any>
const props = Astro.props as Props;
const { label, ...__attrs } = props;
---
<div {...__attrs} class={["badge", __attrs.class].filter(Boolean).join(" ")}>
<slot>
{label}
</slot>
</div>
",
  "qwik/IBadgeBase.tsx": "import { component$, useSignal, useComputed$, useVisibleTask$, $, Slot } from "@qwik.dev/core";
export interface BadgeBaseProps {
  label?: string;
}
export const IBadgeBase = component$((props: BadgeBaseProps & Record<string, any>) =>
{
const { children, label, ...__attrs } = props
return (
<div {...__attrs} class={["badge", props.class].filter(Boolean).join(" ")}>
  <Slot>
    {props.label}
  </Slot>
</div>
)
});
",
  "react/IBadgeBase.tsx": "export interface BadgeBaseProps {
  label?: string;
}
export function IBadgeBase(props: BadgeBaseProps & { children?: React.ReactNode } & React.HTMLAttributes<HTMLElement>)
{
const { children, label, ...__attrs } = props
return (
<div {...__attrs} className={["badge", props.className].filter(Boolean).join(" ")}>
  {props.children ?? props.label}
</div>
)
}
",
  "solid/IBadgeBase.tsx": "import { splitProps } from "solid-js";
import type { JSX } from "solid-js";
export interface BadgeBaseProps {
  label?: string;
}
export default function IBadgeBase(props: BadgeBaseProps & { children?: any } & JSX.HTMLAttributes<HTMLElement>)
{
const [, __attrs] = splitProps(props, ["children", "label"])
return (
<div {...__attrs} class={["badge", props.class].filter(Boolean).join(" ")}>
  {props.children ?? props.label}
</div>
)
}
",
  "svelte/IBadgeBase.svelte": "<script lang="ts">
  export interface BadgeBaseProps {
    label?: string;
  }
  import type { Snippet } from "svelte";
  let { label, children, ...__attrs }: BadgeBaseProps & { children?: Snippet } & Record<string, any> = $props()
</script>
<div {...__attrs} class={["badge", __attrs.class].filter(Boolean).join(" ")}>
  {#if children}{@render children()}{:else}{label}{/if}
</div>
",
  "vue/IBadgeBase.vue": "<script setup lang="ts">
  export interface BadgeBaseProps {
    label?: string;
  }
  const props = defineProps<BadgeBaseProps>()
</script>
