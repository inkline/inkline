  /** Color variant. */
  color?: InputStylingProps["color"];
  /** Style variant. */
  variant?: InputStylingProps["variant"];
  /** Size variant. */
  size?: InputStylingProps["size"];
  /** Invalid-state styling. */
  invalid?: InputStylingProps["invalid"];
}
export const IInput = component$((props: InputProps & { value?: string; onUpdateValue$?: QRL<(value: string) => void> } & Record<string, any>) =>
{
