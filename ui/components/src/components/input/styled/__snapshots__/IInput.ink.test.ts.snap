  "svelte/IInput.svelte": "<script lang="ts">
  import IInputGroupBase from "../headless/IInputGroupBase.svelte";
  import IInputBase from "../headless/IInputBase.svelte";
  import IInputPrefixBase from "../headless/IInputPrefixBase.svelte";
  import IInputSuffixBase from "../headless/IInputSuffixBase.svelte";
  import IInputPrependBase from "../headless/IInputPrependBase.svelte";
  import IInputAppendBase from "../headless/IInputAppendBase.svelte";
  import IInputControlBase, { type InputControlBaseProps } from "../headless/IInputControlBase.svelte";
  import {
    inputRecipe,
    inputGroupRecipe,
    inputPrefixRecipe,
    inputSuffixRecipe,
    type InputRecipeProps as InputStylingProps,
  } from "virtual:styleframe";
  export interface InputProps extends InputControlBaseProps {
    /** Color variant. */
    color?: InputStylingProps["color"];
    /** Style variant. */
    variant?: InputStylingProps["variant"];
    /** Size variant. */
    size?: InputStylingProps["size"];
    /** Invalid-state styling. */
    invalid?: InputStylingProps["invalid"];
  }
  import type { Snippet } from "svelte";
  let { color, variant, size, invalid, id, name, type, placeholder, disabled, readonly, value = $bindable(), prefix: prefixSnippet, suffix: suffixSnippet, prepend: prependSnippet, append: appendSnippet, ...__attrs }: InputProps & { value?: string; prefix?: Snippet; suffix?: Snippet; prepend?: Snippet; append?: Snippet } & Record<string, any> = $props()
  let groupClassName = $derived(inputGroupRecipe({ size: size }))
  let shellClassName = $derived(inputRecipe({ color: color, variant: variant, size: size, invalid: invalid, disabled: disabled, readonly: readonly }))
</script>
<IInputGroupBase {...__attrs} class={[groupClassName, __attrs.class].filter(Boolean).join(" ")}>
  {#if (prependSnippet != null)}<IInputPrependBase>
    {@render prependSnippet?.()}
  </IInputPrependBase>
  {/if}<IInputBase class={shellClassName}>
    {#if (prefixSnippet != null)}<IInputPrefixBase class={inputPrefixRecipe({ size: size })}>
      {@render prefixSnippet?.()}
    </IInputPrefixBase>
    {/if}<IInputControlBase bind:value={value} id={id} name={name} type={type} placeholder={placeholder} disabled={disabled} readonly={readonly} />
    {#if (suffixSnippet != null)}<IInputSuffixBase class={inputSuffixRecipe({ size: size })}>
      {@render suffixSnippet?.()}
    </IInputSuffixBase>
    {/if}
  </IInputBase>
  {#if (appendSnippet != null)}<IInputAppendBase>
    {@render appendSnippet?.()}
  </IInputAppendBase>
  {/if}
</IInputGroupBase>
