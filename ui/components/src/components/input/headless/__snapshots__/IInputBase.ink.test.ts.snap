export interface InputBaseProps {
  /** Id of the field shell element. */
  id?: string;
}
@Component({ standalone: true, selector: 'ink-input-base', host: { style: 'display: contents' }, template: \`<div [class]="'input' + (klass() ? ' ' + klass() : '')" [attr.id]="(id()) ?? null">
