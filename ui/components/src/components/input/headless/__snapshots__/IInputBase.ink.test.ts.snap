</div>\` })
export class IInputBaseComponent
{
klass = input<string>()
id = input<string>()
}
@Component({ standalone: true, selector: 'div[ink-input-base]', host: { '[class]': "'input' + (klass() ? ' ' + klass() : '')", '[attr.id]': "(id()) ?? null" }, template: \`<ng-content></ng-content>\` })
