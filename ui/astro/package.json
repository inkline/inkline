{
  "name": "@inkline/astro",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "validate": "vp check",
    "test": "vp test --passWithNoTests",
    "storybook": "storybook dev -p 6012",
    "storybook:build": "storybook build -o storybook-static",
    "prestorybook": "pnpm --filter @inkline/storybook run generate"
  },
  "devDependencies": {
    "@inkline/components": "workspace:*",
    "@inkline/storybook": "workspace:*",
    "@storybook-astro/framework": "catalog:",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "astro": "^5",
    "@styleframe/plugin": "^3.3.0",
    "@styleframe/theme": "^3.7.0",
    "jsdom": "catalog:",
    "storybook": "catalog:",
    "styleframe": "^3.7.0"
  },
  "dependencies": {
    "@styleframe/runtime": "^3.1.0"
  },
  "peerDependencies": {
    "astro": ">=4"
  },
  "prepublishOnly": "vp run build"
}
