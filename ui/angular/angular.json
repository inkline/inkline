{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "inkline-angular": {
      "root": "",
      "sourceRoot": "generated",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/app",
            "tsConfig": "tsconfig.storybook.json"
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "inkline-angular:build",
            "tsConfig": "tsconfig.storybook.json",
            "compodoc": false,
            "port": 6010
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "inkline-angular:build",
            "tsConfig": "tsconfig.storybook.json",
            "compodoc": false,
            "outputDir": "storybook-static"
          }
        }
      }
    }
  }
}
