{
  "name": "@inkline/angular",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js",
    "./headless": "./dist/headless.js",
    "./stories": "./dist/stories.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp build",
    "validate": "vp check",
    "test": "vp test --passWithNoTests",
    "storybook": "storybook dev -p 6010",
    "storybook:build": "storybook build -o storybook-static",
    "prestorybook": "pnpm --filter @inkline/components exec inkline compile 'src/**/*.ink.tsx' --config inkline.config.ts --target angular"
  },
  "dependencies": {
    "@styleframe/runtime": "catalog:"
  },
  "devDependencies": {
    "@analogjs/storybook-angular": "catalog:",
    "@analogjs/vite-plugin-angular": "catalog:",
    "@angular/build": "catalog:",
    "@angular/cli": "catalog:",
    "@angular/compiler": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@angular/core": "catalog:",
    "@angular/platform-browser": "catalog:",
    "@angular/platform-browser-dynamic": "catalog:",
    "@inkline/components": "workspace:*",
    "@inkline/storybook": "workspace:*",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/angular": "catalog:",
    "@styleframe/cli": "catalog:",
    "@styleframe/core": "catalog:",
    "@styleframe/license": "catalog:",
    "@styleframe/loader": "catalog:",
    "@styleframe/plugin": "catalog:",
    "@styleframe/theme": "catalog:",
    "@styleframe/transpiler": "catalog:",
    "jsdom": "catalog:",
    "rxjs": "catalog:",
    "storybook": "catalog:",
    "styleframe": "catalog:",
    "tslib": "catalog:",
    "typescript": "catalog:ts6",
    "zone.js": "catalog:"
  },
  "peerDependencies": {
    "@angular/core": ">=17"
  },
  "prepublishOnly": "vp run build"
}
