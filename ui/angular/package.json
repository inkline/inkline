{
  "name": "@inkline/angular",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp build",
    "validate": "vp check",
    "test": "vp test --passWithNoTests",
    "storybook": "storybook dev -p 6010",
    "storybook:build": "storybook build -o storybook-static",
    "prestorybook": "pnpm --filter @inkline/storybook run generate"
  },
  "devDependencies": {
    "@analogjs/storybook-angular": "catalog:",
    "@analogjs/vite-plugin-angular": "catalog:",
    "@angular/build": "catalog:",
    "@angular/cli": "catalog:",
    "@angular/compiler": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@angular/core": "catalog:",
    "@angular/platform-browser": "catalog:",
    "@angular/platform-browser-dynamic": "catalog:",
    "@inkline/core": "workspace:*",
    "@inkline/storybook": "workspace:*",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/angular": "catalog:",
    "jsdom": "catalog:",
    "rxjs": "^7",
    "storybook": "catalog:",
    "tslib": "^2",
    "typescript": "catalog:",
    "zone.js": "^0.15"
  },
  "peerDependencies": {
    "@angular/core": ">=17"
  },
  "prepublishOnly": "vp run build"
}
