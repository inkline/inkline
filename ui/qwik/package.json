{
  "name": "@inkline/qwik",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.qwik.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp build",
    "validate": "vp check",
    "test": "vp test --passWithNoTests",
    "storybook": "storybook dev -p 6011",
    "storybook:build": "storybook build -o storybook-static",
    "prestorybook": "pnpm --filter @inkline/cli exec node ./bin/inkline.mjs compile stories"
  },
  "dependencies": {
    "@styleframe/runtime": "^3.1.0"
  },
  "devDependencies": {
    "@inkline/components": "workspace:*",
    "@inkline/storybook": "workspace:*",
    "@qwik.dev/core": "^2.0.0-beta.0",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@styleframe/plugin": "^3.3.0",
    "@styleframe/theme": "^3.7.0",
    "jsdom": "catalog:",
    "storybook": "catalog:",
    "storybook-framework-qwik": "catalog:",
    "styleframe": "^3.7.0"
  },
  "peerDependencies": {
    "@qwik.dev/core": ">=2.0.0-beta.0"
  },
  "prepublishOnly": "vp run build",
  "qwik": "./dist/index.qwik.mjs"
}
