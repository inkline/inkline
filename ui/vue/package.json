{
  "name": "@inkline/vue",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js",
    "./css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp build",
    "validate": "vp check",
    "test": "vp test --passWithNoTests",
    "storybook": "storybook dev -p 6007",
    "storybook:build": "storybook build -o storybook-static",
    "prestorybook": "pnpm --filter @inkline/cli exec node ./bin/inkline.mjs compile stories"
  },
  "dependencies": {
    "@styleframe/runtime": "^3.1.0"
  },
  "devDependencies": {
    "@inkline/components": "workspace:*",
    "@inkline/storybook": "workspace:*",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/vue3-vite": "catalog:",
    "@styleframe/plugin": "^3.3.0",
    "@styleframe/theme": "^3.7.0",
    "@vitejs/plugin-vue": "catalog:",
    "jsdom": "catalog:",
    "storybook": "catalog:",
    "styleframe": "^3.7.0",
    "vue": "^3"
  },
  "peerDependencies": {
    "vue": ">=3"
  },
  "prepublishOnly": "vp run build"
}
