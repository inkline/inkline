{
  "name": "@inkline/test-utils",
  "version": "0.1.0",
  "description": "Cross-target testing utilities for Inkline .ink.tsx components.",
  "homepage": "https://github.com/inkline/inkline#readme",
  "bugs": {
    "url": "https://github.com/inkline/inkline/issues"
  },
  "license": "MIT",
  "author": "Inkline contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inkline/inkline.git",
    "directory": "tooling/test-utils"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@inkline/compiler": "workspace:*",
    "typescript": "catalog:ts6"
  },
  "devDependencies": {
    "@ampproject/remapping": "catalog:",
    "@angular/compiler": "catalog:",
    "@angular/core": "catalog:",
    "@angular/platform-browser": "catalog:",
    "@angular/platform-server": "catalog:",
    "@jridgewell/trace-mapping": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vue/server-renderer": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rxjs": "catalog:",
    "solid-js": "catalog:",
    "svelte": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:"
  },
  "peerDependencies": {
    "@angular/compiler": ">=17",
    "@angular/core": ">=17",
    "@angular/platform-browser": ">=17",
    "@angular/platform-server": ">=17",
    "@vue/server-renderer": ">=3.4",
    "react": ">=18",
    "react-dom": ">=18",
    "solid-js": ">=1.8",
    "svelte": ">=5",
    "vitest": "*",
    "vue": ">=3.4"
  },
  "peerDependenciesMeta": {
    "@angular/compiler": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "@angular/platform-browser": {
      "optional": true
    },
    "@angular/platform-server": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "@vue/server-renderer": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  }
}
