{
  "name": "@inkline/storybook",
  "version": "0.0.0",
  "private": true,
  "description": "Single-source story definitions and shared Storybook configuration for Inkline's per-framework component packages.",
  "homepage": "https://github.com/inkline/inkline#readme",
  "bugs": {
    "url": "https://github.com/inkline/inkline/issues"
  },
  "license": "MIT",
  "author": "Inkline contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inkline/inkline.git",
    "directory": "tooling/storybook"
  },
  "bin": {
    "inkline-storybook": "./bin/inkline-storybook.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./preset/main": {
      "types": "./dist/preset/main.d.mts",
      "default": "./dist/preset/main.mjs"
    },
    "./preset/parameters": {
      "types": "./dist/preset/parameters.d.mts",
      "default": "./dist/preset/parameters.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "generate": "node --import tsx src/bin/generate.ts generate"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsx": "^4.8.1",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
