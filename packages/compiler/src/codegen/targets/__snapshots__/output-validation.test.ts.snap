const sum = createMemo(() => x() + y())
return (
<div>
  <span>
    {sum()}
  </span>
  <button onclick={() => batch(() => { setX(x() + 1); setY(y() + 1); })}>
    Both
  </button>
</div>
)
}
"
`;

