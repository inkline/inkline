exports[`full output snapshots > DynamicList > react 1`] = `
""use client";
import { useState } from "react";
export function DynamicList(props: Record<string, never>)
{
const [items, setItems] = useState([])
const [input, setInput] = useState("")
return (
<div>
  <input value={input} onInput={e => setInput(e.target.value)} />
  <button onClick={() => { setItems([...items, input]); setInput(""); }}>
    Add
  </button>
  <ul>
    {items.map((item) => (<React.Fragment key={(item, i) => i}>{item => <li>{item}</li>}</React.Fragment>))}
  </ul>
</div>
)
}
"
`;

