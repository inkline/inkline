exports[`full output snapshots > SwitchTabs > react 1`] = `
""use client";
import { useState } from "react";
export function SwitchTabs(props: Record<string, never>)
{
const [tab, setTab] = useState("a")
return (
<div>
  {tab === "a" ? (<>...</>) : tab === "b" ? (<>...</>) : null}
  <button onClick={() => setTab(tab === "a" ? "b" : "a")}>
    Switch
  </button>
</div>
)
}
"
`;

exports[`full output snapshots > SwitchTabs > solid 1`] = `
"import { createSignal, Switch, Match } from "solid-js";
export default function SwitchTabs(props: Record<string, never>)
{
const [tab, setTab] = createSignal("a")
return (
<div>
  <Switch>
    <Match when={tab() === "a"}>
      <p>
        Tab A
      </p>
    </Match>
    <Match when={tab() === "b"}>
      <p>
        Tab B
      </p>
    </Match>
  </Switch>
  <button onclick={() => setTab(tab() === "a" ? "b" : "a")}>
    Switch
  </button>
</div>
)
}
"
`;

exports[`full output snapshots > SwitchTabs > svelte 1`] = `
"<script lang="ts">
  let tab = $state("a")
</script>
<div>
  {#if tab === "a"}<p>
    Tab A
  </p>
  {:else if tab === "b"}<p>
    Tab B
  </p>
  {/if}
  <button onclick="() => setTab(tab === "a" ? "b" : "a")">
    Switch
  </button>
</div>
"
`;

exports[`full output snapshots > SwitchTabs > vue 1`] = `
"<script setup lang="ts">
  import { ref } from "vue";
  const tab = ref("a")
</script>
<template>
<div>
  <p v-if="tab === "a"">
    Tab A
  </p>
  <p v-else-if="tab === "b"">
    Tab B
  </p>
  <button @click="() => setTab(tab === "a" ? "b" : "a")">
    Switch
  </button>
</div>
</template>
"
`;

