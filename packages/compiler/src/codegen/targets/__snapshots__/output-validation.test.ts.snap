exports[`full output snapshots > Composite > react 1`] = `
""use client";
import { useState, useMemo, useEffect } from "react";
export function Composite(props: Record<string, never>)
{
const [x, setX] = useState(1)
const [y, setY] = useState(2)
const sum = useMemo(() => x + y, [x, y])
useEffect(() => { console.log("sum:", sum); }, [sum])
return (
<div>
  <span id="sum">
    {sum}
  </span>
  <button id="incX" onClick={() => setX(x + 1)}>
    +X
  </button>
  <button id="incY" onClick={() => setY(y + 1)}>
    +Y
  </button>
</div>
)
}
"
`;

exports[`full output snapshots > Composite > solid 1`] = `
"import { createSignal, createMemo, createEffect } from "solid-js";
export default function Composite(props: Record<string, never>)
{
const [x, setX] = createSignal(1)
const [y, setY] = createSignal(2)
const sum = createMemo(() => x() + y())
createEffect(() => { console.log("sum:", sum()); })
return (
<div>
  <span id="sum">
    {sum()}
  </span>
  <button id="incX" onclick={() => setX(x() + 1)}>
    +X
  </button>
  <button id="incY" onclick={() => setY(y() + 1)}>
    +Y
  </button>
</div>
)
}
"
`;

