exports[`full output snapshots > BatchUpdates > react 1`] = `
""use client";
import { useState, useMemo } from "react";
export function BatchUpdates(props: Record<string, never>)
{
const [x, setX] = useState(0)
const [y, setY] = useState(0)
const sum = useMemo(() => x + y, [x, y])
return (
<div>
  <span>
    {sum}
  </span>
  <button onClick={() => batch(() => { setX(x + 1); setY(y + 1); })}>
    Both
  </button>
</div>
)
}
"
`;

