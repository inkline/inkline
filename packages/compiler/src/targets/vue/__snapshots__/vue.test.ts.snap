exports[`Vue target > SwitchTabs fixture 1`] = `
"<script setup lang="ts">
import { ref } from 'vue';
const activeTab = ref("home");
</script>

<template>
  <div>
    <nav>
      <button @click='() => {
  activeTab = "home";
}'>
        Home
      </button>
      <button @click='() => {
  activeTab = "profile";
}'>
        Profile
      </button>
      <button @click='() => {
  activeTab = "settings";
}'>
        Settings
      </button>
    </nav>
    <section v-if='activeTab === "home"'>
      <h2>
        Home
      </h2>
      <p>
        Welcome to the home page.
      </p>
    </section>
    <section v-else-if='activeTab === "profile"'>
      <h2>
        Profile
      </h2>
      <p>
        Your profile details go here.
      </p>
    </section>
    <section v-else-if='activeTab === "settings"'>
      <h2>
        Settings
      </h2>
      <p>
        Configure your preferences here.
      </p>
    </section>
    <template v-else>
      <p>
        Unknown tab.
      </p>
    </template>
  </div>
</template>
"
`;
