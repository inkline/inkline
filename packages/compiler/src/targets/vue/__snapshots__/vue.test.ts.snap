exports[`Vue target > Button fixture 1`] = `
"<script setup lang="ts">
import { ref } from 'vue';
const { label, tone } = defineProps<{ label: any; tone?: any }>();
const pressed = ref(false);
</script>

<template>
  <button :class='pressed ? "pressed" : "idle"' @click="() => {
  pressed = true;
}">
    {{ label }}
  </button>
</template>
"
`;

exports[`Vue target > Card fixture 1`] = `
"<script setup lang="ts">
import { useSlots } from 'vue';
const slots = useSlots();
</script>

<template>
  <div class="card">
    <div v-if="slots.header" class="card-header">
      <slot name="header" />
    </div>
    <div class="card-body">
      <slot />
    </div>
    <div v-if="slots.footer" class="card-footer">
      <slot name="footer" :count="3" />
    </div>
  </div>
</template>
"
`;

exports[`Vue target > Conditional fixture 1`] = `
"<script setup lang="ts">
import { ref } from 'vue';
const isVisible = ref(false);
const count = ref(0);
</script>

<template>
  <div>
    <p v-if="isVisible">
      Content is visible
    </p>
    <p v-else>
      Content is hidden
    </p>
    <span v-if="count > 0">
      Count: 
      {{ count }}
    </span>
    <button v-if="isVisible" @click="() => {
  isVisible = false;
}">
      Hide
    </button>
    <template v-else>
      <button @click="() => {
  isVisible = true;
}">
        Show
      </button>
    </template>
    <button @click="() => {
  count = count + 1;
}">
      Increment
    </button>
  </div>
</template>
"
`;

exports[`Vue target > Counter fixture 1`] = `
"<script setup lang="ts">
import { computed, ref, watchEffect } from 'vue';
const count = ref(0);
const doubled = computed(() => count.value * 2);
watchEffect(() => {
  console.log("count is", count.value);
});
</script>

<template>
  <div>
    <p>
      {{ count }}
    </p>
    <p>
      {{ doubled }}
    </p>
    <button @click="() => {
  count = count + 1;
}">
      +1
    </button>
  </div>
</template>
"
`;

