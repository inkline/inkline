exports[`Vue target > FormField fixture 1`] = `
"<script setup lang="ts">
import { onMounted, ref, useTemplateRef } from 'vue';
const name = ref("");
const country = ref("us");
const bio = ref("");
const inputRef = useTemplateRef<HTMLInputElement>('inputRef');
onMounted(() => {
  inputRef.value?.focus();
});
</script>

<template>
  <form>
    <label>
      
        Name
        
      <input v-model="name" type="text" ref="inputRef" />
    </label>
    <label>
      
        Country
        
      <select v-model="country">
        <option value="us">
          United States
        </option>
        <option value="eu">
          European Union
        </option>
        <option value="uk">
          United Kingdom
        </option>
      </select>
    </label>
    <label>
      
        Bio
        
      <textarea v-model="bio" :rows="4" />
    </label>
  </form>
</template>
"
`;

exports[`Vue target > Lifecycle fixture 1`] = `
"<script setup lang="ts">
import { computed, onMounted, onUnmounted, ref, watchEffect } from 'vue';
const count = ref(0);
const title = ref("Inkline");
const heading = computed(() => \`\${title.value} — \${count.value}\`);
watchEffect(() => {
  const id = setInterval(() => {
  count.value = count.value + 1;
}, 1000);
  return () => clearInterval(id);
});
watchEffect(() => {
  document.title = heading.value;
});
onMounted(() => {
  document.title = heading.value;
});
onUnmounted(() => {
  document.title = "Inkline";
});
</script>

<template>
  <div>
    <h1 :style='{ fontWeight: count > 10 ? "bold" : "normal" }'>
      {{ heading }}
    </h1>
    <p>
      Count: 
      {{ count }}
    </p>
    <button @click="() => {
  count = 0;
}">
      Reset
    </button>
    <button @click='() => {
  title = "Updated";
}'>
      Change Title
    </button>
  </div>
</template>
"
`;

