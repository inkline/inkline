exports[`Svelte target > Button fixture 1`] = `
"<script lang="ts">
  let { label, tone } = $props();
  let pressed = $state(false);
</script>

<button class={pressed ? "pressed" : "idle"} onclick={() => {
  pressed = true;
}}>
  {label}
</button>
"
`;

exports[`Svelte target > Card fixture 1`] = `
"<script lang="ts">
  let { children, header, footer } = $props();
</script>

<div class="card">
  {#if header}
    <div class="card-header">
      {@render header()}
    </div>
  {/if}
  <div class="card-body">
    {@render children()}
  </div>
  {#if footer}
    <div class="card-footer">
      {@render footer({ count: 3 })}
    </div>
  {/if}
</div>
"
`;

exports[`Svelte target > Conditional fixture 1`] = `
"<script lang="ts">
  let isVisible = $state(false);
  let count = $state(0);
</script>

<div>
  {#if isVisible}
    <p>
      Content is visible
    </p>
  {:else}
    <p>
      Content is hidden
    </p>
  {/if}
  {#if count > 0}
    <span>
      Count: 
      {count}
    </span>
  {/if}
  {#if isVisible}
    <button onclick={() => {
  isVisible = false;
}}>
      Hide
    </button>
  {:else}
    <button onclick={() => {
  isVisible = true;
}}>
      Show
    </button>
  {/if}
  <button onclick={() => {
  count = count + 1;
}}>
    Increment
  </button>
</div>
"
`;

exports[`Svelte target > Counter fixture 1`] = `
"<script lang="ts">
  let count = $state(0);
  let doubled = $derived(count * 2);
  $effect(() => {
  console.log("count is", count);
});
</script>

<div>
  <p>
    {count}
  </p>
  <p>
    {doubled}
  </p>
  <button onclick={() => {
  count = count + 1;
}}>
    +1
  </button>
</div>
"
`;

