exports[`Svelte target > FormField fixture 1`] = `
"<script lang="ts">
  import { onMount } from 'svelte';
  let name = $state("");
  let country = $state("us");
  let bio = $state("");
  let inputRef: HTMLInputElement;
  onMount(() => {
  inputRef?.focus();
});
</script>

<form>
  <label>
    
        Name
        
    <input bind:value={name} type="text" bind:this={inputRef} />
  </label>
  <label>
    
        Country
        
    <select bind:value={country}>
      <option value="us">
        United States
      </option>
      <option value="eu">
        European Union
      </option>
      <option value="uk">
        United Kingdom
      </option>
    </select>
  </label>
  <label>
    
        Bio
        
    <textarea bind:value={bio} rows={4} />
  </label>
</form>
"
`;

exports[`Svelte target > Lifecycle fixture 1`] = `
"<script lang="ts">
  import { onDestroy, onMount } from 'svelte';
  let count = $state(0);
  let title = $state("Inkline");
  let heading = $derived(\`\${title} — \${count}\`);
  $effect(() => {
  const id = setInterval(() => {
  count = count + 1;
}, 1000);
  return () => clearInterval(id);
});
  $effect(() => {
  document.title = heading;
});
  onMount(() => {
  document.title = heading;
});
  onDestroy(() => {
  document.title = "Inkline";
});
</script>

<div>
  <h1 style:font-weight={count > 10 ? "bold" : "normal"}>
    {heading}
  </h1>
  <p>
    Count: 
    {count}
  </p>
  <button onclick={() => {
  count = 0;
}}>
    Reset
  </button>
  <button onclick={() => {
  title = "Updated";
}}>
    Change Title
  </button>
</div>
"
`;

