exports[`Svelte target > SwitchTabs fixture 1`] = `
"<script lang="ts">
  let activeTab = $state("home");
</script>

<div>
  <nav>
    <button onclick={() => {
  activeTab = "home";
}}>
      Home
    </button>
    <button onclick={() => {
  activeTab = "profile";
}}>
      Profile
    </button>
    <button onclick={() => {
  activeTab = "settings";
}}>
      Settings
    </button>
  </nav>
  {#if activeTab === "home"}
    <section>
      <h2>
        Home
      </h2>
      <p>
        Welcome to the home page.
      </p>
    </section>
  {:else if activeTab === "profile"}
    <section>
      <h2>
        Profile
      </h2>
      <p>
        Your profile details go here.
      </p>
    </section>
  {:else if activeTab === "settings"}
    <section>
      <h2>
        Settings
      </h2>
      <p>
        Configure your preferences here.
      </p>
    </section>
  {:else}
    <p>
      Unknown tab.
    </p>
  {/if}
</div>
"
`;
