  );
}
"
`;

exports[`React target > SwitchTabs fixture 1`] = `
"'use client';

import { useState } from 'react';

export function SwitchTabs() {
  const [activeTab, setActiveTab] = useState("home");

  return (
    <div>
      <nav>
        <button onClick={() => setActiveTab("home")}>
          Home
        </button>
        <button onClick={() => setActiveTab("profile")}>
          Profile
        </button>
        <button onClick={() => setActiveTab("settings")}>
          Settings
        </button>
      </nav>
      {activeTab === "home" ? (
        <section>
          <h2>
            Home
          </h2>
          <p>
            Welcome to the home page.
          </p>
        </section>
      ) : activeTab === "profile" ? (
        <section>
          <h2>
            Profile
          </h2>
          <p>
            Your profile details go here.
          </p>
        </section>
      ) : activeTab === "settings" ? (
        <section>
          <h2>
            Settings
          </h2>
          <p>
            Configure your preferences here.
          </p>
        </section>
      ) : (
        {<p>Unknown tab.</p>}
      )}
    </div>
  );
}
"
`;
