{
  "name": "@inkline/compiler",
  "version": "0.0.0",
  "description": "Inkline compiler: TSX with signal primitives to per-target component output via a typed IR.",
  "homepage": "https://github.com/inkline/inkline#readme",
  "bugs": {
    "url": "https://github.com/inkline/inkline/issues"
  },
  "license": "MIT",
  "author": "Inkline contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inkline/inkline.git",
    "directory": "packages/compiler"
  },
  "bin": {
    "inkline": "./dist/bin/inkline.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "test:emitted-typecheck": "node --experimental-strip-types --experimental-transform-types scripts/test-emitted-typecheck.ts",
    "test:emitted-lint": "node --experimental-strip-types --experimental-transform-types scripts/test-emitted-lint.ts",
    "test:runtime": "node --experimental-strip-types --experimental-transform-types scripts/test-runtime.ts",
    "bench": "node --experimental-strip-types --experimental-transform-types scripts/bench.ts",
    "docs:diagnostics": "node --experimental-strip-types --experimental-transform-types scripts/gen-diagnostics.ts",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@jridgewell/trace-mapping": "^0.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "@vitest/coverage-v8": "catalog:",
    "@vue/server-renderer": "^3.4",
    "bumpp": "^11.0.1",
    "happy-dom": "^15",
    "react": "^19",
    "react-dom": "^19",
    "solid-js": "^1.8",
    "svelte": "^5",
    "tinybench": "^2",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.14",
    "vitest": "catalog:",
    "vue": "^3.4"
  },
  "peerDependencies": {
    "typescript": ">=5.4 <8"
  }
}
