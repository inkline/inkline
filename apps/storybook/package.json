{
  "name": "@inkline/storybook-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n react,vue,solid,astro,app \"pnpm run dev:react\" \"pnpm run dev:vue\" \"pnpm run dev:solid\" \"pnpm run dev:astro\" \"pnpm run storybook\"",
    "dev:react": "BROWSER=none pnpm --filter @inkline/react storybook",
    "dev:vue": "BROWSER=none pnpm --filter @inkline/vue storybook",
    "dev:svelte": "BROWSER=none pnpm --filter @inkline/svelte storybook",
    "dev:solid": "BROWSER=none pnpm --filter @inkline/solid storybook",
    "dev:angular": "BROWSER=none pnpm --filter @inkline/angular storybook",
    "dev:astro": "BROWSER=none pnpm --filter @inkline/astro storybook",
    "storybook": "storybook dev -p 6100",
    "storybook:build": "storybook build -o dist"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/react-vite": "catalog:",
    "concurrently": "catalog:",
    "storybook": "catalog:"
  }
}
